{
  "buildCommand": "npm ci && npm run export",
  "outputDirectory": "web-build",
  "nodeVersion": "20.x",
  "ignoreCommand": "git diff --quiet $VERCEL_GIT_PREVIOUS_SHA $VERCEL_GIT_COMMIT -- . ':!node_modules' ':!.next'",
  "env": [
    "SUPABASE_URL",
    "SUPABASE_KEY"
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
