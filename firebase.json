{
  "hosting": {
    "public": "web-build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/index.js",
        "destination": "/index.js"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
